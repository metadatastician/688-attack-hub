#
# AGENTIC.a2ml — AI agent constraints and capabilities
# Defines what AI agents can and cannot do in this repository.

[metadata]
version = "0.1.0"
last-updated = "2026-04-11"

[agent-permissions]
can-edit-source = true
can-edit-tests = true
can-edit-docs = true
can-edit-config = true
can-create-files = true

[agent-constraints]
# What AI agents must NOT do:
# - Never commit secrets or credentials
# - Never add a network call, eval, or dynamic-code-execution primitive to
#   688-attack-hub.html — see AUDIT.adoc and 0-AI-MANIFEST.a2ml; ci.yml
#   enforces this on every push
# - Never introduce a build step, bundler, or dependency for the game itself
#   — it is a deliberately dependency-free single file
# - Never place state files in repository root (must be in .machine_readable/)
# - Licence is AGPL-3.0-or-later for this repo (metadatastician org
#   convention) — do not swap in MPL-2.0

[maintenance-integrity]
fail-closed = true
require-evidence-per-step = true
allow-silent-skip = false
require-rerun-after-fix = true
release-claim-requires-hard-pass = true

# This repo carries no bot_directives/ — that's a maximal-template module
# this minimal repo doesn't declare (see rsr-profile.a2ml). Methodology is
# just: read 0-AI-MANIFEST.a2ml, then STATE.a2ml, then AUDIT.adoc before
# making any claim about what is or isn't verified here.

[automation-hooks]
# on-enter: read 0-AI-MANIFEST.a2ml, then STATE.a2ml
# on-exit: update STATE.a2ml with session outcomes
# on-commit: ci.yml's `integrity` job is the real gate — see .github/workflows/ci.yml
