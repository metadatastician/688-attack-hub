# SPDX-License-Identifier: MPL-2.0
# Activate development environment
# Install direnv: https://direnv.net/

# Load .tool-versions if asdf is available
if has asdf; then
  use asdf
fi

# Load Guix shell if guix.scm exists
if has guix && [ -f guix.scm ]; then
  use guix
fi

# Project environment variables
export PROJECT_NAME="{{PROJECT_NAME}}"
export RSR_TIER="infrastructure"
# Add non-secret project env vars above (e.g. DATABASE_URL, service endpoints).
# Real secrets belong in .env (gitignored) — never commit them to .envrc.

# Source .env if it exists (gitignored)
dotenv_if_exists
